PORT=8080
DATABASE_URL=postgresql://user:password@host:5432/emblem
DATABASE_SSL=true
SESSION_SECRET=replace-me
SESSION_TTL_DAYS=7
SESSION_COOKIE_NAME=session
ADMIN_EMAIL=admin@emblem.studio
ADMIN_PASSWORD=admin
ADMIN_PASSWORD_HASH=
CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
TRUST_PROXY=false
UPLOAD_DIR=uploads
UPLOAD_MAX_MB=10

# Production overrides
# DATABASE_SSL=true
# CORS_ORIGIN=https://<your-vercel-app>.vercel.app
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# TRUST_PROXY=true
# Prefer ADMIN_PASSWORD_HASH over ADMIN_PASSWORD in production
